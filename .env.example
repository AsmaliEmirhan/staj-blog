# ==========================================================
# UYGULAMA AYARLARI
# ==========================================================

APP_NAME="Staj Blog"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://staj-blog.test
APP_TIMEZONE=Europe/Istanbul

# Uygulamaya özel gizli anahtar gerçek .env dosyasında oluşturulacaktır.
APP_KEY=


# ==========================================================
# VERİTABANI AYARLARI
# ==========================================================

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=staj_blog
DB_USERNAME=staj_blog_user
DB_PASSWORD=change_me


# ==========================================================
# OTURUM AYARLARI
# ==========================================================

SESSION_NAME=staj_blog_session

# Oturum süresi dakika cinsindendir.
SESSION_LIFETIME=120

# Yerel HTTP ortamında false, üretimde HTTPS kullanılırken true olmalıdır.
SESSION_SECURE_COOKIE=false


# ==========================================================
# YAPAY ZEKÂ AYARLARI
# ==========================================================

# Kullanılacak AI sağlayıcısı ileride kesinleştirilecektir.
AI_PROVIDER=

# Gerçek API anahtarı yalnızca .env dosyasında bulunmalıdır.
AI_API_KEY=

AI_MODEL=

# Bir kullanıcının günlük AI içerik üretme sınırı.
AI_DAILY_LIMIT=5


# ==========================================================
# LOG AYARLARI
# ==========================================================

LOG_LEVEL=debug